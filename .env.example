# =============================================================================
# Ambient Weather MCP Server - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git! It contains secrets.
# The .gitignore file already excludes it.

# Get both keys from: https://dashboard.ambientweather.net/account

# Application Key: Identifies YOUR APPLICATION (the MCP server).
AMBIENT_APP_KEY=your-application-key-here

# API Key: Identifies YOU (the user) and grants read-only access to your devices.
AMBIENT_API_KEY=your-api-key-here

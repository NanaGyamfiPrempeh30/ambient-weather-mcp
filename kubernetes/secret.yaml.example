# Kubernetes Secret Template for Ambient Weather MCP Server
#
# HOW TO USE:
#   1. Copy this file to kubernetes/secret.yaml
#        cp kubernetes/secret.yaml.example kubernetes/secret.yaml
#   2. Replace the placeholder values with your real credentials
#   3. Apply to your cluster:
#        kubectl apply -f kubernetes/secret.yaml
#
# WARNING: kubernetes/secret.yaml is in .gitignore and must NEVER be committed.
#          It contains real API keys. Keep it local or inject via an external
#          secrets operator (e.g. External Secrets Operator, Sealed Secrets).
#
# Get your API key and application key from:
#   https://ambientweather.net/account

apiVersion: v1
kind: Secret
metadata:
  name: ambient-weather-mcp-secrets
  namespace: ambient-weather-mcp
type: Opaque
stringData:
  # Required: Your Ambient Weather API key
  AMBIENT_API_KEY: "<your-api-key>"

  # Required: Your Ambient Weather application key
  AMBIENT_APP_KEY: "<your-application-key>"

  # Optional: How long to cache weather data in seconds (default: 60)
  CACHE_TTL_SECONDS: "60"

  # Optional: Logging verbosity — DEBUG, INFO, WARNING, ERROR (default: INFO)
  LOG_LEVEL: "INFO"
